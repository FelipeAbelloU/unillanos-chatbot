# =============================================================
# Variables de entorno del Asistente Normativo Unillanos
# Copia este archivo como ".env" y ajusta los valores.
# El archivo .env NUNCA debe subirse a git.
# =============================================================

# Puerto donde corre la API REST (por defecto 8000)
# API_PORT=8000

# Hosts permitidos en la API (separados por coma, * para todos)
# ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
